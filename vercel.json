{
    "version": 2,
    "builds": [
        {
            "src": "src/index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/((?!.*\\.\\w+$).*)",
            "dest": "/src/index.js"
        }
    ],
    "functions": {
        "src/index.js": {
            "runtime": "nodejs18.x",
            "maxDuration": 30
        }
    }
}